{
  "name": "typescript-template",
  "version": "1.0.0",
  "author": "Susumu Tomita <oyster880@gmail.com>",
  "license": "MIT",
  "scripts": {
    "install:all": "cd packages/frontend && bun install && cd ../backend && bun install",
    "dev": "cd packages/frontend && bun run dev",
    "build": "cd packages/frontend && bun run build && cd ../backend && bun run build",
    "clean": "bunx rimraf node_modules && cd packages/frontend && bunx rimraf node_modules dist && cd ../backend && bunx rimraf node_modules dist",
    "test": "cd packages/frontend && bun run test && cd ../backend && bun run test",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "lint:text": "bunx textlint ./README.md",
    "lint-staged": "lint-staged",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format .",
    "typecheck": "cd packages/frontend && bun run typecheck && cd ../backend && bun run typecheck",
    "prepare": "husky",
    "start:frontend": "cd packages/frontend && bun run dev",
    "start:backend": "cd packages/backend && bun run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "rimraf": "^6.1.2",
    "textlint": "^15.4.1",
    "@textlint-ja/textlint-rule-preset-ai-writing": "^1.6.1",
    "textlint-rule-ja-no-abusage": "^3.0.0",
    "textlint-rule-ja-no-inappropriate-words": "^2.0.0",
    "textlint-rule-no-double-negative-ja": "^2.0.1",
    "textlint-rule-no-dropping-the-ra": "^3.0.0",
    "textlint-rule-prefer-tari-tari": "^1.0.3",
    "textlint-rule-preset-ja-spacing": "^2.2.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-spellcheck-tech-word": "^5.0.0"
  }
}
